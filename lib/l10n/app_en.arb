  "exercisePushUps": "Push-ups",
  "exercisePushUpsCue": "Chest to the floor with control.",
  "exercisePushUpsHowTo": "Start in a high plank with hands under your shoulders. Lower your chest toward the floor, keeping elbows close to your body, then press back up. Keep your body in a straight line from head to heels.",
  
  "exerciseKneePushUps": "Knee push-ups",
  "exerciseKneePushUpsCue": "Same as push-ups, from the knees.",
  "exerciseKneePushUpsHowTo": "Kneel on the floor and place your hands under your shoulders. Keep a straight line from knees to head. Lower your chest toward the floor, then press back up with control.",
  
  "exerciseChairDips": "Chair dips",
  "exerciseChairDipsCue": "Lower until elbows are near 90°.",
  "exerciseChairDipsHowTo": "Sit on the edge of a sturdy chair, hands beside your hips. Slide forward so your hips clear the seat. Bend your elbows to lower your body, then press up. Keep shoulders down and away from your ears.",
  
  "exerciseSquats": "Squats",
  "exerciseSquatsCue": "Sit back, chest up, heels down.",
  "exerciseSquatsHowTo": "Stand with feet about shoulder-width apart. Sit your hips back as if into a chair, keep your chest lifted, and lower until thighs are roughly parallel to the floor (or as deep as comfortable). Drive through your heels to stand.",
  
  "exerciseLunges": "Lunges",
  "exerciseLungesCue": "Alternate legs. Count every step.",
  "exerciseLungesHowTo": "Step one foot forward and bend both knees until the back knee nearly touches the floor. Keep your front knee above your ankle. Push back to standing and switch legs. Count total reps across both sides.",
  
  "exerciseGluteBridge": "Glute bridge",
  "exerciseGluteBridgeCue": "Squeeze at the top, then lower.",
  "exerciseGluteBridgeHowTo": "Lie on your back with knees bent and feet flat on the floor. Press through your heels to lift your hips until your body forms a straight line from shoulders to knees. Squeeze your glutes at the top, then lower slowly.",
  
  "exerciseCalfRaises": "Calf raises",
  "exerciseCalfRaisesCue": "Rise onto your toes, pause, lower.",
  "exerciseCalfRaisesHowTo": "Stand tall with feet hip-width apart. Rise onto the balls of your feet as high as you can, pause briefly, then lower with control. Hold a wall or chair for balance if needed.",
  
  "exercisePlank": "Plank",
  "exercisePlankCue": "Hold a straight line — no sagging.",
  "exercisePlankHowTo": "Place forearms on the floor with elbows under shoulders, or hold a high plank on your hands. Keep your body straight from head to heels. Brace your core, squeeze your glutes, and breathe steadily. Stop if your form breaks.",
  
  "exerciseSidePlank": "Side plank",
  "exerciseSidePlankCue": "Log the weaker side's time.",
  "exerciseSidePlankHowTo": "Lie on one side with your elbow under your shoulder. Lift your hips so your body forms a straight line. Hold, then switch sides. Log the time of your weaker side.",
  
  "exerciseDeadBug": "Dead bug",
  "exerciseDeadBugCue": "Slow moves, back pressed down.",
  "exerciseDeadBugHowTo": "Lie on your back with arms toward the ceiling and knees bent at 90°. Slowly extend opposite arm and leg toward the floor without letting your lower back arch. Return and switch sides. One rep = both sides once.",
  
  "exerciseBirdDog": "Bird dog",
  "exerciseBirdDogCue": "Opposite arm and leg, then switch.",
  "exerciseBirdDogHowTo": "Start on all fours with hands under shoulders and knees under hips. Extend one arm forward and the opposite leg back, keeping hips level. Pause, return, then switch. One rep = both sides once.",
  
  "exerciseJumpingJacks": "Jumping jacks",
  "exerciseJumpingJacksCue": "Steady rhythm, soft landings.",
  "exerciseJumpingJacksHowTo": "Stand with feet together and arms at your sides. Jump your feet out while raising your arms overhead, then jump back to the start. Land softly and keep a steady pace.",
  
  "exerciseHighKnees": "High knees",
  "exerciseHighKneesCue": "Drive knees up, stay light.",
  "exerciseHighKneesHowTo": "Jog in place while driving your knees up toward hip height. Pump your arms and stay on the balls of your feet. Count each knee drive as one rep.",
  
  "exerciseMountainClimbers": "Mountain climbers",
  "exerciseMountainClimbersCue": "Hips level as you switch legs.",
  "exerciseMountainClimbersHowTo": "Start in a high plank. Drive one knee toward your chest, then quickly switch legs as if running in place. Keep hips low and level. Count each knee drive as one rep.",
  
  "exerciseUnknown": "Unknown exercise",
  "exerciseUnknownCue": "This exercise is no longer in the catalog.",
  "exerciseUnknownHowTo": "Skip or re-take your assessment to refresh your plan."
